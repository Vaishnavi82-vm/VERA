GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Comma-separated browser origins (must match the URL bar of your Vite app, scheme + host + port)
CORS_ORIGINS=http://127.0.0.1:8080,http://127.0.0.1:5173,http://localhost:8080,http://localhost:5173
MONGO_URI=
# Optional: name of the MongoDB database to use (defaults to `vera_db`)
MONGO_DB=vera_db
